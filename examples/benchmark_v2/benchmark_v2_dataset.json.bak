{
  "name": "OrKa Brain v2 Benchmark Dataset",
  "version": "2.0.0",
  "description": "Comprehensive benchmark evaluating Brain v2 skills + GraphScout routing vs stateless baseline. Five tracks: cross-domain transfer, anti-pattern avoidance, GraphScout routing, multi-skill composition, and longitudinal learning curves. 250 tasks x 2 conditions = 500+ execution runs.",
  "tracks": {
    "A": {
      "name": "Cross-Domain Skill Transfer",
      "description": "Learn procedural patterns in seed domains, then test transfer to 40 novel domains. Measures whether brain-recalled skills improve output quality in unseen contexts.",
      "task_count": 50,
      "phases": {"learn": 10, "recall": 40}
    },
    "B": {
      "name": "Anti-Pattern Avoidance",
      "description": "Seed 10 anti-patterns, then present 40 tasks that could trigger them. Measures whether the brain prevents known bad patterns.",
      "task_count": 50,
      "phases": {"seed_anti": 10, "test_avoid": 40}
    },
    "C": {
      "name": "GraphScout Brain-Assisted Routing",
      "description": "Seed path skills, then use GraphScout with brain_assisted=true for routing decisions. Measures routing quality and confidence with vs without brain path knowledge.",
      "task_count": 50,
      "phases": {"seed_path": 10, "route": 40}
    },
    "D": {
      "name": "Multi-Skill Composition",
      "description": "Tasks requiring recall and composition of multiple skill types (recipe + anti-pattern + path). Measures combined skill application.",
      "task_count": 50,
      "phases": {"seed": 10, "compose": 40}
    },
    "E": {
      "name": "Longitudinal Learning Curve",
      "description": "50 sequential software engineering tasks in the same domain. Measures whether brain condition improves over time via skill accumulation and feedback loops.",
      "task_count": 50,
      "phases": {"sequential": 50}
    }
  },
  "tasks": [
    {
      "task_id": "track_a_01",
      "track": "A",
      "phase": "learn",
      "domain": "data_engineering",
      "title": "Learn: Extract-Transform-Load Pipeline",
      "task": "Design and implement an ETL pipeline that extracts data from multiple CSV sources, transforms it by cleaning nulls, normalizing date formats, and deduplicating records, then loads the results into a structured data warehouse schema.",
      "execution_trace": {
        "steps": [
          {"action": "identify and catalog all data sources with schema inspection", "result": "success"},
          {"action": "extract raw data with error handling for malformed rows", "result": "success"},
          {"action": "apply type coercion and null-handling transformations", "result": "success"},
          {"action": "normalize date formats to ISO 8601 across all sources", "result": "success"},
          {"action": "deduplicate records using composite key matching", "result": "success"},
          {"action": "validate transformed data against target schema constraints", "result": "success"},
          {"action": "load validated records into warehouse with transaction safety", "result": "success"}
        ],
        "agents": ["source_scanner", "extractor", "type_coercer", "date_normalizer", "deduplicator", "schema_validator", "loader"],
        "strategy": "sequential"
      },
      "outcome": {"success": true, "quality": 0.92}
    },
    {
      "task_id": "track_a_02",
